# --- Service ---
PORT=8080
LOG_LEVEL=INFO
ENVIRONMENT=local

# --- LLM providers (litellm picks one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

DEFAULT_LLM_MODEL=anthropic/claude-sonnet-4-5
FALLBACK_LLM_MODELS=openai/gpt-5,gemini/gemini-2.5-flash

# --- LangFuse tracing ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Resend (qualified-lead notifications) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@amplyd.com
OWNER_EMAIL=vincent.juhel@gmail.com

# --- Owner contact (gated by qualify_lead → reveal_phone) ---
OWNER_PHONE=

# --- Content corpus ---
# Where the agent reads MDX from at startup. In dev we point at the local
# web app's content/ (gitignored). In prod the Docker image bakes a copy in.
CONTENT_DIR=../web/content

# --- CORS / security ---
ALLOWED_ORIGINS=http://localhost:3000,https://amplyd.com
AGENT_API_TOKEN=
