# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- CV content (production override) ---
# Optional. JSON-stringified arrays/object. If absent, the loader falls back
# to apps/web/content/*.json and finally apps/web/content.example/*.json.
AMPLYD_TIMELINE_EN=
AMPLYD_TIMELINE_FR=
AMPLYD_PROJECTS_EN=
AMPLYD_PROJECTS_FR=
AMPLYD_EDUCATION_EN=
AMPLYD_EDUCATION_FR=
AMPLYD_SKILLS_EN=
AMPLYD_SKILLS_FR=
AMPLYD_PREFERENCES_EN=
AMPLYD_PREFERENCES_FR=

# --- Agent backend (Cloud Run) ---
# At dev: point to your local FastAPI: http://localhost:8080
# In prod: https://mcp.amplyd.com
AGENT_BASE_URL=http://localhost:8080
AGENT_API_TOKEN=

# --- Auth.js v5 (Google OAuth) ---
# Generate: openssl rand -hex 32
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Optional in dev; required in prod
AUTH_TRUST_HOST=true

# --- Vercel KV (rate limiting) ---
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Resend (transactional email + qualified-lead notifications) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@amplyd.com
OWNER_EMAIL=

# --- Cal.com (booking embed) ---
# URL pattern: https://cal.eu/{username}/{event-slug}
NEXT_PUBLIC_CALCOM_USERNAME=vincent-juhel-jvhelq
NEXT_PUBLIC_CALCOM_EVENT_SLUG=30min
NEXT_PUBLIC_CALCOM_HOST=cal.eu
