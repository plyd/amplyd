{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "**/.env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "!.env.example"
      ],
      "env": [
        "AMPLYD_TIMELINE_EN",
        "AMPLYD_TIMELINE_FR",
        "AMPLYD_PROJECTS_EN",
        "AMPLYD_PROJECTS_FR",
        "AMPLYD_EDUCATION_EN",
        "AMPLYD_EDUCATION_FR",
        "AUTH_SECRET",
        "AUTH_TRUST_HOST",
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXTAUTH_URL",
        "KV_URL",
        "KV_REST_API_URL",
        "KV_REST_API_TOKEN",
        "KV_REST_API_READ_ONLY_TOKEN",
        "AGENT_BASE_URL",
        "AGENT_API_TOKEN"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  }
}
