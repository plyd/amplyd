# --- Vincent's private data — NEVER commit ---
# The CV JSON content under apps/web/content/{timeline,projects,education,
# skills,preferences}.{en,fr}.json is intentionally public (long-form
# narrative + anecdotes, all designed to be read by the agent and visitors).
# Profile MDX and unfinished article drafts stay local until they're polished.
_private/
apps/web/content/profile.*.mdx
apps/web/content/articles/

# --- Node / pnpm / Turbo ---
node_modules/
.pnpm-store/
.turbo/
.next/
out/
dist/
build/
.cache/
*.tsbuildinfo
next-env.d.ts

# --- Env files ---
.env
.env.*
!.env.example

# --- OAuth client secret JSON dropped at repo root ---
client_secret_*.json

# --- Python (apps/agent) ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env.venv
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/

# --- Terraform ---
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/terraform/*.tfvars
!infra/terraform/*.tfvars.example
infra/terraform/.terraform.lock.hcl

